NODE_ENV=development
PORT=5000
ALLOWED_ORIGINS=http://localhost:5173
MONGODB_URI=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
JWT_SECRET=change-me
BACKEND_URL=https://your-backend.example.com
FRONTEND_URL=http://localhost:5173

# ─── Meta / WhatsApp Cloud API ───
# Fill these in after you receive credentials from Meta
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_VERIFY_TOKEN=himalayan_yoga_verify
META_GRAPH_VERSION=v22.0

# ─── WhatsApp Flow ───
# Generated by: npm run flow:create (after Meta credentials are set)
WHATSAPP_FLOW_ID=
WHATSAPP_FLOW_STATUS=DRAFT

# ─── Flow Endpoint Encryption (RSA keypair) ───
# Generated by: npm run flow:keys
FLOW_PRIVATE_KEY=
FLOW_PUBLIC_KEY=

# ─── Cloudinary (image & PDF storage) ───
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Meta Native WhatsApp Pay ───
# Name of the payment configuration in Meta Business Manager → WhatsApp Payments
META_PAYMENT_CONFIG_NAME=yogaaccademy
# Razorpay credentials linked to the Meta payment config (MCC: 8299, Purpose: 00)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Razorpay webhook secret (set in Razorpay Dashboard → Settings → Webhooks)
# Webhook URL: https://<your-backend>/api/payment/razorpay-webhook
RAZORPAY_WEBHOOK_SECRET=

# ─── Optional: driver phone for W4 arrival day message ───
DRIVER_PHONE=

# ─── Optional: review links for W5 Day 3 ───
GOOGLE_REVIEW_LINK=
TRIPADVISOR_LINK=
